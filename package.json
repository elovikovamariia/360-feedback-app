{
  "name": "360-feedback-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:export-snapshot": "tsx scripts/gh-pages-snapshot.ts",
    "build:gh-pages": "prisma generate && prisma db push && npm run db:seed && npm run db:export-snapshot && node scripts/stash-api.mjs stash && node scripts/run-gh-pages-build.mjs && node scripts/stash-api.mjs restore"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "next": "13.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "13.5.6",
    "postcss": "^8.5.2",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=16.14.0"
  }
}
