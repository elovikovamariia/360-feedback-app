# SQLite file is used by default (see prisma/schema.prisma)
# Один файл для CLI и приложения (от корня репозитория)
DATABASE_URL="file:./prisma/dev.db"

# --- LLM (часто OpenRouter: sk-or-v1-...) ---
# Скопируйте этот блок в свой .env (файл .env не коммитьте).
# 1) Вставьте выданный ключ целиком в OPENAI_API_KEY
# 2) Обязательно укажите BASE_URL для OpenRouter (иначе запрос уйдёт на api.openai.com и вернётся ошибка)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# У OpenRouter модель задаётся строкой провайдера, например:
OPENAI_MODEL=openai/gpt-4o-mini
# Если OpenRouter ругается на отсутствие Referer (редко):
# OPENROUTER_HTTP_REFERER=http://localhost:3000
#
# Без OPENAI_API_KEY отчёт строится локально по той же схеме JSON (без вызова внешнего API).
