# SQLite file is used by default (see prisma/schema.prisma)
# Один файл для CLI и приложения (от корня репозитория)
DATABASE_URL="file:./prisma/dev.db"

# Optional: OpenAI for AI reports. If unset, a deterministic demo report is generated.
OPENAI_API_KEY=
# Optional override (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1
